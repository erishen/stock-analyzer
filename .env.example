# 数据模式选择
DATA_MODE=real

# API Keys (用于获取实时市场数据)
# Tushare API: https://tushare.pro/register
TUSHARE_TOKEN=

# Alpha Vantage API: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Finnhub API: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# AI 分析配置（可选）
DEEPSEEK_API_KEY=
AI_MODEL=deepseek-chat

# 数据路径配置
# 共享数据库路径（所有 InvestKit 项目共用）
# asset-lens 数据库默认位于 investkit_utils/data/asset_lens.db
# ASSET_LENS_DB_PATH=../investkit_utils/data/asset_lens.db

# 分析数据库路径（ETL 输出，含技术指标）
# STOCK_ANALYSIS_DB_PATH=data/stock_analysis.db

# K线数据库路径（从 AkShare 直接获取的数据）
# STOCK_KLINES_DB_PATH=data/stock_klines.db

# 输出路径
DATA_PATH=data
OUTPUT_PATH=output
CACHE_PATH=cache

# 环境变量同步（可选）
# 用于从其他项目同步 .env 文件
# SYNC_ENV_SOURCE=/path/to/external/.env
