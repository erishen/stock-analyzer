# 数据模式选择
DATA_MODE=real

# API Keys (用于获取实时市场数据)
# Tushare API: https://tushare.pro/register
TUSHARE_TOKEN=

# Alpha Vantage API: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Finnhub API: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# AI 分析配置（可选）
DEEPSEEK_API_KEY=
AI_MODEL=deepseek-chat

# 数据路径配置
DATA_PATH=data
OUTPUT_PATH=output
CACHE_PATH=cache

# 环境变量同步（可选）
# 用于从其他项目同步 .env 文件
# SYNC_ENV_SOURCE=/path/to/external/.env
